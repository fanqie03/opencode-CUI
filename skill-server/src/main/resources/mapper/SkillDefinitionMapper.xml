<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.opencode.cui.skill.repository.SkillDefinitionRepository">

    <resultMap id="SkillDefinitionResultMap" type="com.opencode.cui.skill.model.SkillDefinition">
        <id     property="id"          column="id"/>
        <result property="skillCode"   column="skill_code"/>
        <result property="skillName"   column="skill_name"/>
        <result property="toolType"    column="tool_type"/>
        <result property="description" column="description"/>
        <result property="iconUrl"     column="icon_url"/>
        <result property="status"      column="status"
                typeHandler="org.apache.ibatis.type.EnumTypeHandler"
                javaType="com.opencode.cui.skill.model.SkillDefinition$Status"/>
        <result property="sortOrder"   column="sort_order"/>
        <result property="createdAt"   column="created_at"/>
        <result property="updatedAt"   column="updated_at"/>
    </resultMap>

    <sql id="selectAllColumns">
        SELECT id, skill_code, skill_name, tool_type, description, icon_url,
               status, sort_order, created_at, updated_at
        FROM skill_definition
    </sql>

    <select id="findAll" resultMap="SkillDefinitionResultMap">
        <include refid="selectAllColumns"/>
        ORDER BY sort_order ASC
    </select>

    <select id="findById" resultMap="SkillDefinitionResultMap">
        <include refid="selectAllColumns"/>
        WHERE id = #{id}
    </select>

    <select id="findBySkillCode" resultMap="SkillDefinitionResultMap">
        <include refid="selectAllColumns"/>
        WHERE skill_code = #{skillCode}
    </select>

    <select id="findByStatus" resultMap="SkillDefinitionResultMap">
        <include refid="selectAllColumns"/>
        WHERE status = #{status}
    </select>

    <select id="findByStatusOrderBySortOrderAsc" resultMap="SkillDefinitionResultMap">
        <include refid="selectAllColumns"/>
        WHERE status = #{status}
        ORDER BY sort_order ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO skill_definition
            (skill_code, skill_name, tool_type, description, icon_url, status, sort_order, created_at, updated_at)
        VALUES
            (#{skillCode}, #{skillName}, #{toolType}, #{description}, #{iconUrl},
             #{status}, #{sortOrder}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE skill_definition
        SET skill_code   = #{skillCode},
            skill_name   = #{skillName},
            tool_type    = #{toolType},
            description  = #{description},
            icon_url     = #{iconUrl},
            status       = #{status},
            sort_order   = #{sortOrder},
            updated_at   = NOW()
        WHERE id = #{id}
    </update>

</mapper>
